{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": ".electron-dist",
    "noEmit": false,
    "target": "ES2020",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "isolatedModules": false
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["node_modules", "src", ".next"]
}
