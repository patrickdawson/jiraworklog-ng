{
  "name": "jiraworklog-ng",
  "version": "0.1.0",
  "private": true,
  "main": ".electron-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node scripts/db-sample.mjs seed",
    "db:unseed": "node scripts/db-sample.mjs clean",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "electron:dev": "wait-on http://localhost:3000 && tsc --project tsconfig.electron.json && electron .",
    "dev:electron": "concurrently --kill-others \"npm run dev\" \"npm run electron:dev\"",
    "electron:compile": "tsc --project tsconfig.electron.json",
    "electron:start": "npm run electron:compile && electron ."
  },
  "dependencies": {
    "@react-pdf/renderer": "4.5.1",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "electron": "^34.5.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "menubar": "^9.5.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
